# ==============================================
# Customer Support Intelligence — Environment Config
# ==============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- GCP Configuration ---
# Your GCP project ID (run: gcloud projects list)
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Set to TRUE for Vertex AI, FALSE for Google AI Studio API key
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# --- Google AI Studio (alternative to Vertex AI) ---
# Get a free key at: https://ai.google.dev
# GOOGLE_API_KEY=your-api-key-here

# --- Model Configuration ---
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768

# --- RAG Configuration ---
CHUNK_SIZE=512
CHUNK_OVERLAP=128
RAG_TOP_K=5
CACHE_SIMILARITY_THRESHOLD=0.95

# --- BigQuery ---
BQ_DATASET=support_analytics
BQ_TABLE=interactions

# --- Local Development Fallbacks ---
# Set to true to use SQLite instead of BigQuery
USE_LOCAL_ANALYTICS=false
